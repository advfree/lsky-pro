APP_URL=https://your-domain.example
APP_KEY=

DB_DATABASE=lsky
DB_USERNAME=lsky
DB_PASSWORD=change-this-database-password
MYSQL_ROOT_PASSWORD=change-this-root-password

HTTP_PORT=8080

# 可选：NAS/NFS 挂载到宿主机后的 Lsky Pro 存储总路径。
# 后台“NAS 存储与备份”里填写同一个路径，例如 /mnt/nas/lskypro。
LSKY_STORAGE_BASE_PATH=/mnt/nas/lskypro

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
