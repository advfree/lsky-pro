APP_NAME="Lsky Pro"
APP_ENV=prod
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (supports: mysql, pgsql, sqlite, sqlsrv)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lsky
DB_USERNAME=lsky
DB_PASSWORD=

BROADCAST_DRIVER=log

# Cache (supports: file, redis, memcached)
CACHE_DRIVER=file

FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

# Session (supports: file, redis, cookie, database)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

IGNITION_SHARING_ENABLED=false

# Docker environment variables (for docker-compose)
# APP_PORT=8080
# DB_ROOT_PASSWORD=root_secret_pass
# APP_RUN_IN_DOCKER=true
